# 複製成 .env 後填入(本機測試用;Render 上改在後台 Environment 設定)

# ---- LINE Messaging API(從 LINE Developers 的 channel 取得)----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- 使用者白名單(逗號分隔的 LINE userId)----
# 先留空 → setup 模式(所有人可用,並在 log 印出 userId)。
# 收集到 Amy / Yira 的 userId 後填進來,例如:
# ALLOWED_USER_IDS=Uxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyy
ALLOWED_USER_IDS=

# ---- 文案顯示 ----
ORG_NAME=樹德企業
BOT_NAME=樹德市場觀察室
